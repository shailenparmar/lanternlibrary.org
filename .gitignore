# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!server/.env.example

# python (server/)
server/.venv/
server/__pycache__/
server/lantern_reflect/__pycache__/
server/transcripts/
*.pyc

# drizzle
/drizzle/0*.sql
/drizzle/meta

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
