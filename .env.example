# Lantern Library — env vars
#
# Copy to .env.local and fill in. .env.local is gitignored.

# /read agent (required for Claude-guided story discovery on the home page)
ANTHROPIC_API_KEY=

# Postgres + pgvector (optional — leave commented out to use in-memory data).
# To turn on: run `npm run db:up && npm run db:push && npm run db:seed`
# and uncomment the line below.
# DATABASE_URL=postgres://lantern:lantern@localhost:5433/lanternlibrary
