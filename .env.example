# Lantern Library — env vars
#
# Copy to .env.local and fill in. .env.local is gitignored.

# /read agent (required for Claude-guided story discovery at /read)
ANTHROPIC_API_KEY=

# Postgres + pgvector (optional — app falls back to in-memory data if unset)
# Default value matches docker-compose.yml. Run `npm run db:up` then `npm run db:push` and `npm run db:seed`.
DATABASE_URL=postgres://lantern:lantern@localhost:5433/lanternlibrary
